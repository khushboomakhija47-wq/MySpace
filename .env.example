# Required for real team invitation email delivery.
# Gmail example: host=smtp.gmail.com, port=587, user=your Gmail address,
# pass=a Google App Password (not your normal account password).
TADA_SMTP_HOST=smtp.gmail.com
TADA_SMTP_PORT=587
TADA_SMTP_USER=
TADA_SMTP_PASS=
TADA_SMTP_FROM=Tada <your-email@example.com>

# Public URL recipients should open. Localhost works only on your computer.
TADA_APP_URL=http://127.0.0.1:5173
